{
  "name": "devtidy-vscode",
  "displayName": "DevTidy",
  "description": "Find and safely reclaim stale developer artifacts (node_modules, virtualenvs, build caches) without leaving VS Code.",
  "version": "0.1.1",
  "publisher": "harish-ai-engineer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/harish-ai-engineer/devtidy.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "cleanup",
    "disk-space",
    "node_modules",
    "cache",
    "developer-tools"
  ],
  "icon": "media/icon.png",
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devtidy",
          "title": "DevTidy",
          "icon": "media/devtidy.svg"
        }
      ]
    },
    "views": {
      "devtidy": [
        {
          "id": "devtidyCandidates",
          "name": "Stale Artifacts",
          "icon": "media/devtidy.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "devtidyCandidates",
        "contents": "Scan your workspace for stale build artifacts, caches, and environments.\n[Scan Workspace](command:devtidy.scan)\nScanning never deletes anything. DevTidy requires the [devtidy CLI](https://pypi.org/project/devtidy/) (`pipx install devtidy`)."
      }
    ],
    "commands": [
      {
        "command": "devtidy.scan",
        "title": "Scan Workspace",
        "category": "DevTidy",
        "icon": "$(refresh)"
      },
      {
        "command": "devtidy.archiveItem",
        "title": "Archive (Restorable)",
        "category": "DevTidy",
        "icon": "$(archive)"
      },
      {
        "command": "devtidy.deleteItem",
        "title": "Delete Permanently",
        "category": "DevTidy",
        "icon": "$(trash)"
      },
      {
        "command": "devtidy.archiveAll",
        "title": "Archive All Candidates",
        "category": "DevTidy"
      },
      {
        "command": "devtidy.deleteAll",
        "title": "Delete All Candidates",
        "category": "DevTidy"
      },
      {
        "command": "devtidy.restoreLatest",
        "title": "Restore Latest Archive",
        "category": "DevTidy",
        "icon": "$(history)"
      },
      {
        "command": "devtidy.revealItem",
        "title": "Reveal in File Explorer",
        "category": "DevTidy"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devtidy.scan",
          "when": "view == devtidyCandidates",
          "group": "navigation@1"
        },
        {
          "command": "devtidy.restoreLatest",
          "when": "view == devtidyCandidates",
          "group": "navigation@2"
        },
        {
          "command": "devtidy.archiveAll",
          "when": "view == devtidyCandidates",
          "group": "actions@1"
        },
        {
          "command": "devtidy.deleteAll",
          "when": "view == devtidyCandidates",
          "group": "actions@2"
        }
      ],
      "view/item/context": [
        {
          "command": "devtidy.archiveItem",
          "when": "view == devtidyCandidates && viewItem == candidate",
          "group": "inline@1"
        },
        {
          "command": "devtidy.deleteItem",
          "when": "view == devtidyCandidates && viewItem == candidate",
          "group": "inline@2"
        },
        {
          "command": "devtidy.archiveItem",
          "when": "view == devtidyCandidates && viewItem == candidate",
          "group": "1_actions@1"
        },
        {
          "command": "devtidy.deleteItem",
          "when": "view == devtidyCandidates && viewItem == candidate",
          "group": "1_actions@2"
        },
        {
          "command": "devtidy.revealItem",
          "when": "view == devtidyCandidates && viewItem == candidate",
          "group": "2_navigation@1"
        }
      ],
      "commandPalette": [
        {
          "command": "devtidy.archiveItem",
          "when": "false"
        },
        {
          "command": "devtidy.deleteItem",
          "when": "false"
        },
        {
          "command": "devtidy.revealItem",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "DevTidy",
      "properties": {
        "devtidy.command": {
          "type": "string",
          "default": "devtidy",
          "description": "Command used to run the DevTidy CLI. May contain arguments, e.g. \"python -m devtidy\". If it cannot be found, \"python -m devtidy\" and \"py -m devtidy\" are tried as fallbacks."
        },
        "devtidy.olderThan": {
          "type": "string",
          "default": "",
          "markdownDescription": "Only report artifacts idle for at least this long, e.g. `30d`, `12h`. Empty means no age filter."
        },
        "devtidy.minSize": {
          "type": "string",
          "default": "",
          "markdownDescription": "Only report artifacts of at least this size, e.g. `100MB`. Empty means no size filter."
        },
        "devtidy.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns (matched against relative paths or directory names) to exclude from scans."
        },
        "devtidy.maxDepth": {
          "type": "number",
          "default": 0,
          "description": "Maximum scan depth below each workspace folder. 0 means unlimited."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
